<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">
    <fragment android:id="@+id/splashFragment" android:name="com.nammapustaka.ui.auth.SplashFragment" android:label="Splash">
        <action android:id="@+id/action_splash_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/splashFragment" app:popUpToInclusive="true" />
        <action android:id="@+id/action_splash_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/splashFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/loginFragment" android:name="com.nammapustaka.ui.auth.LoginFragment" android:label="Login">
        <action android:id="@+id/action_login_to_register" app:destination="@id/registerFragment" app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left" app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_login_to_home" app:destination="@id/homeFragment" app:popUpTo="@id/loginFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/registerFragment" android:name="com.nammapustaka.ui.auth.RegisterFragment" android:label="Register">
        <action android:id="@+id/action_register_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/registerFragment" app:popUpToInclusive="true" />
    </fragment>
    <fragment android:id="@+id/homeFragment" android:name="com.nammapustaka.ui.home.HomeFragment" android:label="Home">
        <action android:id="@+id/action_home_to_catalog" app:destination="@id/catalogFragment" app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left" app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
        <action android:id="@+id/action_home_to_leaderboard" app:destination="@id/leaderboardFragment" />
        <action android:id="@+id/action_home_to_reports" app:destination="@id/reportsFragment" />
        <action android:id="@+id/action_home_to_profile" app:destination="@id/profileFragment" app:enterAnim="@anim/slide_in_right" app:exitAnim="@anim/slide_out_left" app:popEnterAnim="@anim/slide_in_left" app:popExitAnim="@anim/slide_out_right" />
    </fragment>
    <fragment android:id="@+id/catalogFragment" android:name="com.nammapustaka.ui.catalog.CatalogFragment" android:label="Catalog">
        <action android:id="@+id/action_catalog_to_detail" app:destination="@id/bookDetailFragment" />
        <action android:id="@+id/action_catalog_to_addBook" app:destination="@id/addBookFragment" />
    </fragment>
    <fragment android:id="@+id/bookDetailFragment" android:name="com.nammapustaka.ui.catalog.BookDetailFragment" android:label="Book Detail">
        <argument android:name="bookId" app:argType="integer" android:defaultValue="0" />
        <action android:id="@+id/action_detail_to_review" app:destination="@id/addReviewFragment" />
        <action android:id="@+id/action_detail_to_edit" app:destination="@id/editBookFragment" />
    </fragment>
    <fragment android:id="@+id/addBookFragment" android:name="com.nammapustaka.ui.catalog.AddBookFragment" android:label="Add Book" />
    <fragment android:id="@+id/editBookFragment" android:name="com.nammapustaka.ui.catalog.EditBookFragment" android:label="Edit Book">
        <argument android:name="bookId" app:argType="integer" android:defaultValue="0" />
    </fragment>
    <fragment android:id="@+id/scanFragment" android:name="com.nammapustaka.ui.scan.ScanFragment" android:label="Scan" />
    <fragment android:id="@+id/studentsFragment" android:name="com.nammapustaka.ui.students.StudentsFragment" android:label="Students">
        <action android:id="@+id/action_students_to_detail" app:destination="@id/studentDetailFragment" />
        <action android:id="@+id/action_students_to_addStudent" app:destination="@id/addStudentFragment" />
    </fragment>
    <fragment android:id="@+id/studentDetailFragment" android:name="com.nammapustaka.ui.students.StudentDetailFragment" android:label="Student">
        <argument android:name="studentId" app:argType="integer" android:defaultValue="0" />
    </fragment>
    <fragment android:id="@+id/addStudentFragment" android:name="com.nammapustaka.ui.students.AddStudentFragment" android:label="Add Student" />
    <fragment android:id="@+id/leaderboardFragment" android:name="com.nammapustaka.ui.leaderboard.LeaderboardFragment" android:label="Leaderboard" />
    <fragment android:id="@+id/reportsFragment" android:name="com.nammapustaka.ui.reports.ReportsFragment" android:label="Reports" />
    <fragment android:id="@+id/addReviewFragment" android:name="com.nammapustaka.ui.review.AddReviewFragment" android:label="Add Review">
        <argument android:name="bookId" app:argType="integer" android:defaultValue="0" />
    </fragment>
    <fragment android:id="@+id/profileFragment" android:name="com.nammapustaka.ui.profile.ProfileFragment" android:label="Profile">
        <action android:id="@+id/action_profile_to_login" app:destination="@id/loginFragment" app:popUpTo="@id/nav_graph" app:popUpToInclusive="true" />
    </fragment>
</navigation>
